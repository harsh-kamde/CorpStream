# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in your values
# NEVER commit .env to Git
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# Your MCP server API key — anyone with this can call your tools
# Generate: openssl rand -hex 32
API_KEY=your_strong_api_key_here

# Internal key for Lambda → EC2 communication (different from API_KEY)
# Generate: openssl rand -hex 32
INTERNAL_KEY=your_internal_key_here

# ── Database (AWS RDS PostgreSQL) ─────────────────────────────────────────────
# Get endpoint from: terraform output rds_endpoint
DATABASE_URL=postgresql://mcpuser:password@your-rds-endpoint.rds.amazonaws.com:5432/companies?sslmode=require

# ── AWS (set via IAM role on EC2 — no keys needed when running on EC2) ────────
# Only needed for local development
AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=     # Only for local dev — EC2 uses IAM role
# AWS_SECRET_ACCESS_KEY= # Only for local dev — EC2 uses IAM role

# Get from: terraform output s3_bucket_name
S3_BUCKET=global-company-mcp-exports-xxxx

# ── Companies House UK (free API key) ─────────────────────────────────────────
# Register at: https://developer.company-information.service.gov.uk
# Takes ~2 minutes, instant approval
CH_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── SEC EDGAR USA (no key needed) ─────────────────────────────────────────────
# Just set your email — SEC requires User-Agent header
CONTACT_EMAIL=your@email.com

# ── Apify (for MCA India scraping) ────────────────────────────────────────────
# Register at: https://apify.com — free tier = 5 compute units/month
# Get token from: https://console.apify.com/account/integrations
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxx

# After deploying the MCA actor (apify push), get the actor ID from Apify console
MCA_ACTOR_ID=YOUR_APIFY_USERNAME/mca-india-scraper

# ── OpenCorporates (optional — free tier 500 req/day without key) ─────────────
# Register at: https://opencorporates.com/api_accounts/new
# Without key: limited to 500 requests/day
OPENCORP_API_KEY=

# ── data.gov.in (MCA bulk dataset fallback — free) ────────────────────────────
# Default key works for testing, get your own for production:
# https://data.gov.in/user/register
DATA_GOV_API_KEY=579b464db66ec23bdd000001cdd3946e44ce4aab825d70c01ca5
